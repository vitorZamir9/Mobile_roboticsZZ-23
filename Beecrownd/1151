import java.util.Scanner

fun main(args: Array<String>) {
    val sc = Scanner(System.`in`)

    if (sc.hasNextInt()) {
        val n = sc.nextInt()
        
        var anterior = 0
        var atual = 1
        
        for (i in 1..n) {
            if (i == n) {
                print("$anterior")
            } else {
                print("$anterior ")
                
                val proximo = anterior + atual
                anterior = atual
                atual = proximo
            }
        }
        println()
    }
}
